# Copy this file to .env and fill in the values before running docker compose.

# Required: random 32+ character string
AUTH_SECRET=change-me-to-a-random-32-char-string

# Public URL of the app — use your Pi's IP or hostname for Raspberry Pi installs
AUTH_URL=http://localhost:3000

# Optional: SMTP for email notifications (leave empty to disable)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASS=your-smtp-password
# SMTP_FROM=3D Print CMS <noreply@example.com>
# SMTP_SECURE=false
