// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TEAM_MEMBER
}

enum PrintJobStatus {
  PLANNED
  SLICED
  IN_PROGRESS
  AWAITING_VERIFICATION
  DONE
  CANCELLED
}

enum FileSource {
  CUSTOMER
  TEAM
}

enum OrderType {
  PRINT_ONLY
  DESIGN
}

enum FileCategory {
  REFERENCE
  DESIGN
  RESULT
  OTHER
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VerificationType {
  DESIGN_REVIEW
  PRICE_APPROVAL
}

enum QuoteStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  EXPIRED
  SUPERSEDED
}

enum QuoteItemCategory {
  FILAMENT
  HARDWARE
  POST_PROCESSING
  DESIGN
  SHIPPING
  DISCOUNT
  OTHER
}

enum QuoteItemSource {
  ESTIMATE
  FIXED
  ACTUAL
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  SEPA
  CASH
  PAYPAL
  CREDIT
  CARD
  OTHER
}

enum PasswordResetKind {
  USER
  CUSTOMER
}


model User {
  id               String                  @id @default(cuid())
  name             String
  email            String                  @unique
  password         String
  role             Role                    @default(TEAM_MEMBER)
  locale           String                  @default("de")
  createdAt        DateTime                @default(now())
  onboardedAt      DateTime?
  assignedOrders   OrderAssignee[]
  comments         OrderComment[]
  auditLogs        AuditLog[]
  accounts         Account[]
  sessions         Session[]
  knowledgeEntries KnowledgeEntry[]
  projectAssignees ProjectAssignee[]
  projectAuditLogs ProjectAuditLog[]
  partAssignees    OrderPartAssignee[]
  taskAssignees    MilestoneTaskAssignee[]
  jobAssignees     PrintJobAssignee[]
  fileNotes        OrderFileNote[]
  projectComments  ProjectComment[]
  calendarEvents   CalendarEvent[]
}

model ProjectPhase {
  id        String    @id @default(cuid())
  name      String
  color     String    @default("#6366f1")
  position  Int       @default(0)
  isDefault Boolean   @default(false)
  projects  Project[]
}

model OrderPhase {
  id          String  @id @default(cuid())
  name        String
  color       String  @default("#6366f1")
  position    Int
  isDefault   Boolean @default(false)
  isSurvey    Boolean @default(false)
  isPrototype Boolean @default(false)
  isArchive   Boolean @default(false)
  enterGate   Json?
  autoAdvance Json?
  orders      Order[]
}

model PartPhase {
  id           String      @id @default(cuid())
  name         String
  color        String      @default("#6366f1")
  position     Int
  isDefault    Boolean     @default(false)
  isPrintReady Boolean     @default(false)
  isReview     Boolean     @default(false)
  isPrinted    Boolean     @default(false)
  isMisprint   Boolean     @default(false)
  enterGate    Json?
  autoAdvance  Json?
  orderParts   OrderPart[]
}

model Order {
  id             String           @id @default(cuid())
  trackingToken  String           @unique @default(cuid())
  customerName   String
  customerEmail  String
  customerId     String?
  customer       Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  description    String           @db.Text
  phase          OrderPhase       @relation(fields: [phaseId], references: [id])
  phaseId        String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  archivedAt     DateTime?
  deadline       DateTime?
  phaseOrder     Int?
  priceEstimate  Decimal?         @db.Decimal(10, 2)
  orderType      OrderType        @default(PRINT_ONLY)
  isPrototype    Boolean          @default(false)
  iterationCount Int              @default(1)
  isInternal     Boolean          @default(false)
  generalProject Boolean          @default(false)
  estimatedCompletionAt DateTime?
  projectId      String?
  project        Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assignees      OrderAssignee[]
  files          OrderFile[]
  sourceLinks    OrderSourceLink[]
  comments       OrderComment[]
  auditLogs      AuditLog[]
  parts                 OrderPart[]
  surveyResponse        SurveyResponse?
  verificationRequests  VerificationRequest[]
  milestones            Milestone[]
  sprints               Sprint[]
  quotes                Quote[]
  invoices              Invoice[]

  @@index([customerId])
}

model Filament {
  id               String             @id @default(cuid())
  name             String
  material         String
  color            String
  colorHex         String?
  brand            String?
  spoolWeightGrams Int
  remainingGrams   Int
  pricePerKg       Decimal?           @db.Decimal(10, 2)
  notes            String?            @db.Text
  isActive         Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  orderParts        OrderPart[]
  printJobFilaments PrintJobFilament[]
}

model Machine {
  id           String     @id @default(cuid())
  name         String
  buildVolumeX Int
  buildVolumeY Int
  buildVolumeZ Int
  hourlyRate   Decimal?   @db.Decimal(10, 2)
  notes        String?    @db.Text
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  printJobs    PrintJob[]
}

model PrintJob {
  id               String             @id @default(cuid())
  machineId        String
  machine          Machine            @relation(fields: [machineId], references: [id])
  status           PrintJobStatus     @default(PLANNED)
  shortCode        String?            @unique
  queuePosition    Int                @default(0)
  plannedAt        DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  printTimeMinutes    Int?
  printTimeFromGcode  Boolean            @default(false)
  notes               String?            @db.Text
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  parts            PrintJobPart[]
  filamentUsages   PrintJobFilament[]
  files            PrintJobFile[]
  assignees        PrintJobAssignee[]
}

model PrintJobFile {
  id           String   @id @default(cuid())
  printJob     PrintJob @relation(fields: [printJobId], references: [id], onDelete: Cascade)
  printJobId   String
  filename     String
  originalName String
  mimeType     String
  size         Int
  createdAt    DateTime @default(now())
}

model PrintJobPart {
  printJobId  String
  orderPartId String
  printJob    PrintJob  @relation(fields: [printJobId], references: [id], onDelete: Cascade)
  orderPart   OrderPart @relation(fields: [orderPartId], references: [id], onDelete: Cascade)
  addedAt     DateTime  @default(now())

  @@id([printJobId, orderPartId])
}

model PrintJobFilament {
  id          String   @id @default(cuid())
  printJobId  String
  filamentId  String
  printJob    PrintJob @relation(fields: [printJobId], references: [id], onDelete: Cascade)
  filament    Filament @relation(fields: [filamentId], references: [id])
  gramsActual Int
  createdAt   DateTime @default(now())
}

model OrderPart {
  id             String              @id @default(cuid())
  order          Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId        String
  name           String
  description    String?             @db.Text
  filament       Filament?           @relation(fields: [filamentId], references: [id])
  filamentId     String?
  gramsEstimated   Int?
  gramsActualTotal Int?
  chargedCentsTotal Int?
  bboxXmm          Int?
  bboxYmm        Int?
  bboxZmm        Int?
  orientQx       Float               @default(0)
  orientQy       Float               @default(0)
  orientQz       Float               @default(0)
  orientQw       Float               @default(1)
  quantity       Int                 @default(1)
  iterationCount Int                 @default(1)
  partPhase      PartPhase?          @relation(fields: [partPhaseId], references: [id], onDelete: SetNull)
  partPhaseId    String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  files                 OrderFile[]
  printJobParts         PrintJobPart[]
  assignees             OrderPartAssignee[]
  verificationRequests  VerificationRequest[]
  iterations            OrderPartIteration[]
}

model OrderPartIteration {
  id           String    @id @default(cuid())
  orderPart    OrderPart @relation(fields: [orderPartId], references: [id], onDelete: Cascade)
  orderPartId  String
  pieceIndex   Int
  result       String
  gramsActual  Int
  chargedCents Int?
  chargeReason String?
  printJobId   String?
  verifiedAt   DateTime  @default(now())
  verifiedBy   String?

  @@unique([orderPartId, pieceIndex, printJobId])
  @@index([orderPartId])
}

model OrderAssignee {
  orderId String
  userId  String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([orderId, userId])
}

model OrderPartAssignee {
  orderPartId String
  userId      String
  orderPart   OrderPart @relation(fields: [orderPartId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([orderPartId, userId])
}

model MilestoneTaskAssignee {
  taskId String
  userId String
  task   MilestoneTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
}

model PrintJobAssignee {
  printJobId String
  userId     String
  printJob   PrintJob @relation(fields: [printJobId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([printJobId, userId])
}

model OrderFile {
  id           String     @id @default(cuid())
  order        Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId      String
  orderPart    OrderPart? @relation(fields: [orderPartId], references: [id], onDelete: SetNull)
  orderPartId  String?
  filename     String
  originalName String
  mimeType     String
  size         Int
  source       FileSource   @default(CUSTOMER)
  category     FileCategory @default(DESIGN)
  createdAt    DateTime     @default(now())
  notes        OrderFileNote[]
}

model OrderFileNote {
  id                String    @id @default(cuid())
  orderFile         OrderFile @relation(fields: [orderFileId], references: [id], onDelete: Cascade)
  orderFileId       String
  posX              Float
  posY              Float
  posZ              Float
  normalX           Float
  normalY           Float
  normalZ           Float
  body              String    @db.Text
  isCustomerVisible Boolean   @default(true)
  resolvedAt        DateTime?
  author            User?     @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorId          String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([orderFileId])
}

model OrderSourceLink {
  id        String   @id @default(cuid())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  url       String   @db.Text
  label     String?
  createdAt DateTime @default(now())

  @@index([orderId])
}

model OrderComment {
  id             String   @id @default(cuid())
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId        String
  author         User     @relation(fields: [authorId], references: [id])
  authorId       String
  content        String   @db.Text
  sentToCustomer Boolean  @default(false)
  createdAt      DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  action    String
  details   String?  @db.Text
  createdAt DateTime @default(now())
}

model KnowledgeEntry {
  id        String          @id @default(cuid())
  title     String
  problem   String          @db.Text
  solution  String          @db.Text
  tags      Json     @default("[]")
  files     KnowledgeFile[]
  authorId  String?
  author    User?           @relation(fields: [authorId], references: [id], onDelete: SetNull)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model KnowledgeFile {
  id           String         @id @default(cuid())
  entry        KnowledgeEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  entryId      String
  filename     String
  originalName String
  mimeType     String
  size         Int
  createdAt    DateTime       @default(now())
}

model SurveyResponse {
  id          String    @id @default(cuid())
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId     String    @unique
  token       String    @unique @default(cuid())
  sentAt      DateTime  @default(now())
  submittedAt DateTime?
  answers     Json?
  comment     String?   @db.Text
}

model VerificationRequest {
  id          String             @id @default(cuid())
  order       Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId     String
  orderPart   OrderPart?         @relation(fields: [orderPartId], references: [id], onDelete: Cascade)
  orderPartId String?
  quote       Quote?             @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  quoteId     String?
  type        VerificationType   @default(DESIGN_REVIEW)
  token       String             @unique @default(cuid())
  status      VerificationStatus @default(PENDING)
  sentAt          DateTime           @default(now())
  resolvedAt      DateTime?
  resolvedBy      String?
  rejectionReason String?            @db.Text

  @@index([quoteId])
}

model Quote {
  id           String      @id @default(cuid())
  order        Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId      String
  number       String?     @unique
  version      Int         @default(1)
  status       QuoteStatus @default(DRAFT)
  totalCents   Int         @default(0)
  taxCents     Int         @default(0)
  validUntil   DateTime?
  sentAt       DateTime?
  approvedAt   DateTime?
  rejectedAt   DateTime?
  rejectionReason String?  @db.Text
  notes        String?     @db.Text
  createdById  String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  items        QuoteItem[]
  verificationRequests VerificationRequest[]
  invoices     Invoice[]

  @@unique([orderId, version])
  @@index([orderId])
}

model QuoteItem {
  id              String            @id @default(cuid())
  quote           Quote             @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteId         String
  position        Int               @default(0)
  description     String            @db.Text
  quantity        Decimal           @default(1) @db.Decimal(10, 3)
  unitPriceCents  Int               @default(0)
  taxRatePercent  Decimal           @default(19) @db.Decimal(5, 2)
  category        QuoteItemCategory @default(OTHER)
  source          QuoteItemSource   @default(FIXED)
  orderPartId     String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([quoteId])
}

model Invoice {
  id               String            @id @default(cuid())
  order            Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId          String
  quote            Quote?            @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  quoteId          String?
  number           String?           @unique
  status           InvoiceStatus     @default(DRAFT)
  issuedAt         DateTime?
  dueAt            DateTime?
  cancelledAt      DateTime?
  reverseOfId      String?           @unique
  reverseOf        Invoice?          @relation("InvoiceReversal", fields: [reverseOfId], references: [id])
  reversedBy       Invoice?          @relation("InvoiceReversal")
  totalCents       Int               @default(0)
  taxCents         Int               @default(0)
  kleinunternehmer Boolean           @default(false)
  notes            String?           @db.Text
  pdfPath          String?
  snapshotJson     Json?
  createdById      String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  items            InvoiceItem[]
  payments         Payment[]
  reminders        PaymentReminder[]

  @@index([orderId])
  @@index([status])
  @@index([quoteId])
}

model InvoiceItem {
  id              String            @id @default(cuid())
  invoice         Invoice           @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId       String
  position        Int               @default(0)
  description     String            @db.Text
  quantity        Decimal           @default(1) @db.Decimal(10, 3)
  unitPriceCents  Int               @default(0)
  taxRatePercent  Decimal           @default(19) @db.Decimal(5, 2)
  category        QuoteItemCategory @default(OTHER)
  orderPartId     String?
  createdAt       DateTime          @default(now())

  @@index([invoiceId])
}

model InvoiceNumberCounter {
  id        String  @id @default(cuid())
  prefix    String  @unique
  nextValue Int     @default(1)
  updatedAt DateTime @updatedAt
}

model Payment {
  id           String        @id @default(cuid())
  invoice      Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId    String
  amountCents  Int
  paidAt       DateTime
  method       PaymentMethod
  reference    String?
  notes        String?       @db.Text
  recordedBy   String?
  createdAt    DateTime      @default(now())

  @@index([invoiceId])
}

model PaymentReminder {
  id        String   @id @default(cuid())
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId String
  stage     Int
  sentAt    DateTime @default(now())
  feeCents  Int?     @default(0)

  @@index([invoiceId])
}

model Sprint {
  id         String      @id @default(cuid())
  orderId    String?
  order      Order?      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  projectId  String?
  project    Project?    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name       String
  position   Int         @default(0)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  milestones Milestone[]

  @@index([orderId])
  @@index([projectId])
}

model Milestone {
  id          String          @id @default(cuid())
  orderId     String?
  order       Order?          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprintId    String?
  sprint      Sprint?         @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  name        String
  description String?         @db.Text
  dueAt       DateTime?
  completedAt DateTime?
  color       String          @default("#6366f1")
  position    Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  tasks       MilestoneTask[]

  @@index([sprintId])
}

model MilestoneTask {
  id          String                  @id @default(cuid())
  milestoneId String
  milestone   Milestone               @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  title       String
  completed   Boolean                 @default(false)
  completedAt DateTime?
  position    Int                     @default(0)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  assignees   MilestoneTaskAssignee[]
}

model Project {
  id               String            @id @default(cuid())
  name             String
  description      String?           @db.Text
  projectPhaseId   String
  projectPhase     ProjectPhase      @relation(fields: [projectPhaseId], references: [id])
  phaseOrder       Int               @default(0)
  deadline         DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  archivedAt       DateTime?
  orders           Order[]
  milestones       Milestone[]
  sprints          Sprint[]
  assignees        ProjectAssignee[]
  auditLogs        ProjectAuditLog[]
  files            ProjectFile[]
  comments         ProjectComment[]
}

model ProjectFilePhase {
  id        String        @id @default(cuid())
  name      String
  color     String        @default("#6366f1")
  position  Int           @default(0)
  isDefault Boolean       @default(false)
  files     ProjectFile[]
}

model ProjectFile {
  id           String            @id @default(cuid())
  project      Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId    String
  phase        ProjectFilePhase? @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  phaseId      String?
  filename     String
  originalName String
  mimeType     String
  size         Int
  createdAt    DateTime          @default(now())

  @@index([projectId])
  @@index([phaseId])
}

model ProjectComment {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@index([projectId])
}

model ProjectAssignee {
  projectId String
  userId    String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
}

model ProjectAuditLog {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  action    String
  details   String?  @db.Text
  createdAt DateTime @default(now())
}

model Setting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

// Allgemeiner Termin ohne Auftragsbezug (z. B. Wartung, Messe, Urlaub).
model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  note        String?  @db.Text
  startAt     DateTime
  endAt       DateTime
  allDay      Boolean  @default(true)
  color       String   @default("#64748b")
  ownerId     String?
  owner       User?    @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ownerId])
  @@index([startAt])
}

// Abonnierter Web-Kalender (iCal/ICS, z. B. Ferienkalender). Shop-weit.
model CalendarSubscription {
  id            String    @id @default(cuid())
  name          String
  url           String    @db.Text
  color         String    @default("#0ea5e9")
  isActive      Boolean   @default(true)
  lastFetchedAt DateTime?
  lastError     String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model PasswordResetToken {
  id        String            @id @default(cuid())
  token     String            @unique @default(cuid())
  email     String
  kind      PasswordResetKind
  expires   DateTime
  createdAt DateTime          @default(now())

  @@index([email, kind])
}

model Customer {
  id                 String                          @id @default(cuid())
  email              String                          @unique
  name               String
  password           String
  creditBalanceCents Int                             @default(0)
  locale             String                          @default("de")
  emailVerifiedAt    DateTime?
  createdAt          DateTime                        @default(now())
  updatedAt          DateTime                        @updatedAt
  credits            CustomerCredit[]
  orders             Order[]
  verificationTokens CustomerEmailVerificationToken[]
}

model CustomerEmailVerificationToken {
  token      String   @id @default(cuid())
  customerId String
  expires    DateTime
  createdAt  DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model CustomerCredit {
  id          String   @id @default(cuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  amountCents Int
  reason      String   @db.Text
  orderId     String?
  performedBy String?
  createdAt   DateTime @default(now())

  @@index([customerId])
  @@index([orderId])
}

// Auth.js Standard Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}
